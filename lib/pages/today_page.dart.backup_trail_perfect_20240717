      CurvedAnimation(parent: _ballEntranceControllers[i], curve: Curves.elasticOut),
    ));
    _ballBounceControllers = List.generate(3, (i) => AnimationController(
      vsync: this,
      duration: Duration(milliseconds: 400),
    ));
