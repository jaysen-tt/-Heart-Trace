// 属性条组件
class AttributeBar extends StatelessWidget {
  final double percent; // 0.0~1.0
  final double width;
  final double height;
  final String label;
  final LinearGradient gradient;

  const AttributeBar({
    super.key,
    required this.percent,
    required this.width,
    required this.height,
    required this.label,
    required this.gradient,
  });

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Stack(
          alignment: Alignment.bottomCenter,
          children: [
            Container(
              width: width,
              height: height,
            ),
            Container(
              width: width,
              height: height * percent,
              decoration: BoxDecoration(
                gradient: gradient,
              ),
            ),
            if (percent > 0)
              Positioned(
                top: height * percent - 6.5,
                child: Container(
                  width: 13,
                  height: 13,
                  decoration: BoxDecoration(
                    shape: BoxShape.circle,
                    gradient: gradient,
                  ),
                ),
              ),
          ],
        ),
        SizedBox(height: 8),
        Text(
          label,
          style: TextStyle(
            fontSize: 14,
            fontWeight: FontWeight.w600,
            color: Color(0xFF2C3E50),
          ),
        ),
      ],
    );
  }
}