                                  child: Container(
                                    margin: EdgeInsets.all(2.5),
                                    child: Container(
                                      width: 48,
                                      height: 48,
                                      decoration: BoxDecoration(
                                        color: fillColor,
                                        shape: BoxShape.circle,
                                        border: borderColor != null ? Border.all(color: borderColor, width: 1) : null,
                                      ),
                                    ),
                                  ),
                                );
                              }),
                            );
                          }),
                        ),
                      ],
                    );
                  },
